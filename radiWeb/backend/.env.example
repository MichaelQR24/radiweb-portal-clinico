# ============================================================
# RadiWeb Backend – Variables de Entorno
# Copiar este archivo como .env y rellenar los valores reales
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_super_secret_key_minimum_256_bits_change_this_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_also_minimum_256_bits
JWT_REFRESH_EXPIRES_IN=7d

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=radiWeb_db
DB_USER=root
DB_PASSWORD=tu_contraseña

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_DICOM=dicom-images
AZURE_STORAGE_CONTAINER_PREVIEW=preview-images
AZURE_SAS_EXPIRY_HOURS=2

# URL del Frontend Angular (para CORS)
FRONTEND_URL=http://localhost:4200

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
